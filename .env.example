# -----------------------------------------------------------------------------
# API & SERVER CONFIGURATION
# -----------------------------------------------------------------------------
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# DATABASE & CACHE  (required in production)
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017/couple-chat
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# SECURITY & AUTHENTICATION  (required — generate with: openssl rand -hex 64)
# -----------------------------------------------------------------------------
JWT_SECRET=REPLACE_WITH_STRONG_SECRET

# -----------------------------------------------------------------------------
# AI & OPENAI CONFIGURATION  (required)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_OPENAI_KEY
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_CHAT_MODEL=gpt-3.5-turbo-0125

# -----------------------------------------------------------------------------
# STORAGE — Cloudinary  (required — get from cloudinary.com/console)
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=REPLACE_WITH_YOUR_CLOUD_NAME
CLOUDINARY_API_KEY=REPLACE_WITH_YOUR_API_KEY
CLOUDINARY_API_SECRET=REPLACE_WITH_YOUR_API_SECRET

# -----------------------------------------------------------------------------
# FRONTEND (apps/web)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=REPLACE_WITH_YOUR_CLOUD_NAME
